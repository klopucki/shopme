@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Welcome back, Admin!</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <div class="btn-group me-2">
                <button type="button" class="btn btn-sm btn-outline-secondary">Share</button>
                <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle">
                <i class="bi bi-calendar3"></i> This week
            </button>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-primary text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-0 small text-uppercase fw-bold opacity-75">Total Products</p>
                            <h2 class="mb-0 fw-bold">124</h2>
                        </div>
                        <i class="bi bi-box-seam fs-1 opacity-50"></i>
                    </div>
                    <div class="mt-3 small">
                        <span class="fw-bold">+12%</span> since last month
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-success text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-0 small text-uppercase fw-bold opacity-75">Active Sales</p>
                            <h2 class="mb-0 fw-bold">1,450</h2>
                        </div>
                        <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                    </div>
                    <div class="mt-3 small">
                        <span class="fw-bold">+5.4%</span> vs yesterday
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-warning text-dark">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-0 small text-uppercase fw-bold opacity-75">New Customers</p>
                            <h2 class="mb-0 fw-bold">89</h2>
                        </div>
                        <i class="bi bi-people fs-1 opacity-50"></i>
                    </div>
                    <div class="mt-3 small">
                        <span class="fw-bold">+2</span> registered today
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-danger text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-0 small text-uppercase fw-bold opacity-75">Out of Stock</p>
                            <h2 class="mb-0 fw-bold">7</h2>
                        </div>
                        <i class="bi bi-exclamation-triangle fs-1 opacity-50"></i>
                    </div>
                    <div class="mt-3 small text-decoration-underline cursor-pointer">
                        View details
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Activities -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark">Recent Activity</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light small text-uppercase text-muted">
                                <tr>
                                    <th>Event</th>
                                    <th>User</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Added product "Gaming Laptop"</td>
                                    <td>Admin John</td>
                                    <td><span class="badge bg-success-subtle text-success border border-success-subtle">Success</span></td>
                                    <td class="text-muted">2 mins ago</td>
                                </tr>
                                <tr>
                                    <td>Updated Category "Electronics"</td>
                                    <td>Admin John</td>
                                    <td><span class="badge bg-info-subtle text-info border border-info-subtle">Info</span></td>
                                    <td class="text-muted">1 hour ago</td>
                                </tr>
                                <tr>
                                    <td>Deleted Product #104</td>
                                    <td>Moderator Kate</td>
                                    <td><span class="badge bg-danger-subtle text-danger border border-danger-subtle">Deleted</span></td>
                                    <td class="text-muted">3 hours ago</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-center py-3">
                    <a href="#" class="small text-decoration-none fw-bold">View all activity</a>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-controller="Product" asp-action="Create" class="btn btn-outline-primary text-start p-3">
                            <i class="bi bi-plus-circle me-2"></i> Add New Product
                        </a>
                        <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary text-start p-3">
                            <i class="bi bi-tags me-2"></i> Manage Categories
                        </a>
                        <a href="#" class="btn btn-outline-info text-start p-3">
                            <i class="bi bi-person-plus me-2"></i> Add Team Member
                        </a>
                        <a href="#" class="btn btn-outline-dark text-start p-3">
                            <i class="bi bi-gear me-2"></i> System Settings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .card { border-radius: 12px; }
    .card-header { border-top-left-radius: 12px !important; border-top-right-radius: 12px !important; }
</style>