@model Intranet.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var currentUser = User.Identity?.Name ?? "User";
}

<div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-secondary mb-0">Welcome back, @currentUser. Here is the current intranet snapshot.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Product
        </a>
        <a asp-controller="Article" asp-action="Create" class="btn btn-outline-primary">
            <i class="bi bi-newspaper me-1"></i>Article
        </a>
        <a asp-controller="Page" asp-action="Create" class="btn btn-outline-secondary">
            <i class="bi bi-file-earmark-richtext me-1"></i>Page
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xxl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small text-uppercase fw-semibold">Products</div>
                        <div class="display-6 fw-semibold">@Model.ProductCount</div>
                    </div>
                    <div class="text-primary fs-2"><i class="bi bi-box-seam"></i></div>
                </div>
                <div class="small text-secondary">@Model.FeaturedProductCount featured, @Model.CategoryCount categories</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xxl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small text-uppercase fw-semibold">Stock alerts</div>
                        <div class="display-6 fw-semibold">@Model.OutOfStockProductCount</div>
                    </div>
                    <div class="text-danger fs-2"><i class="bi bi-exclamation-triangle"></i></div>
                </div>
                <div class="small text-secondary">@Model.LowStockProductCount low-stock products</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xxl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small text-uppercase fw-semibold">Portal content</div>
                        <div class="display-6 fw-semibold">@(Model.ArticleCount + Model.PageCount + Model.RankingCount)</div>
                    </div>
                    <div class="text-success fs-2"><i class="bi bi-layout-text-window"></i></div>
                </div>
                <div class="small text-secondary">
                    @(Model.PublishedArticleCount + Model.PublishedPageCount + Model.PublishedRankingCount) published
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xxl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-secondary small text-uppercase fw-semibold">Activity today</div>
                        <div class="display-6 fw-semibold">@Model.AuditLogCountToday</div>
                    </div>
                    <div class="text-info fs-2"><i class="bi bi-activity"></i></div>
                </div>
                <div class="small text-secondary">@Model.UserCount users, @Model.AverageProductRating.ToString("0.0") avg. review</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0 fw-semibold">Stock watch</h2>
                <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.LowStockProducts.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">No low-stock products.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var product in Model.LowStockProducts)
                        {
                            <tr>
                                <td class="fw-semibold">@product.Name</td>
                                <td class="text-secondary">@(product.CategoryName ?? "-")</td>
                                <td class="text-end">
                                    <span class="badge @(product.Quantity <= 0 ? "text-bg-danger" : "text-bg-warning")">@product.Quantity</span>
                                </td>
                                <td class="text-end">@product.Price.ToString("C")</td>
                                <td class="text-end">
                                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0 fw-semibold">Quick actions</h2>
                <span class="badge text-bg-light">@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Product" asp-action="Create" class="btn btn-outline-primary text-start p-3">
                        <i class="bi bi-plus-circle me-2"></i>Add product
                    </a>
                    <a asp-controller="Ranking" asp-action="Create" class="btn btn-outline-secondary text-start p-3">
                        <i class="bi bi-trophy me-2"></i>Create ranking
                    </a>
                    <a asp-controller="Page" asp-action="Index" class="btn btn-outline-secondary text-start p-3">
                        <i class="bi bi-file-earmark-richtext me-2"></i>Manage pages
                    </a>
                    <a asp-controller="User" asp-action="Create" class="btn btn-outline-secondary text-start p-3">
                        <i class="bi bi-person-plus me-2"></i>Add user
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0 fw-semibold">Recent activity</h2>
                <a asp-controller="Audit" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.RecentAuditLogs.Count == 0)
                {
                    <div class="list-group-item text-center text-secondary py-4">No audit activity yet.</div>
                }
                else
                {
                    @foreach (var log in Model.RecentAuditLogs)
                    {
                        <a asp-controller="Audit" asp-action="Details" asp-route-id="@log.Id" class="list-group-item list-group-item-action py-3">
                            <div class="d-flex justify-content-between gap-3">
                                <div>
                                    <div class="fw-semibold">@log.Controller.Replace("Controller", "")</div>
                                    <div class="small text-secondary">@log.Username · @log.HttpMethod</div>
                                </div>
                                <div class="text-end">
                                    <span class="badge @(log.HasException ? "text-bg-danger" : "text-bg-success")">
                                        @(log.HasException ? "Error" : "OK")
                                    </span>
                                    <div class="small text-secondary mt-1">@log.Timestamp.ToLocalTime().ToString("g")</div>
                                </div>
                            </div>
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0 fw-semibold">Latest portal content</h2>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.RecentContent.Count == 0)
                {
                    <div class="list-group-item text-center text-secondary py-4">No portal content yet.</div>
                }
                else
                {
                    @foreach (var item in Model.RecentContent)
                    {
                        <a asp-controller="@item.Controller" asp-action="Edit" asp-route-id="@item.Id" class="list-group-item list-group-item-action py-3">
                            <div class="d-flex justify-content-between gap-3">
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">@item.Title</div>
                                    <div class="small text-secondary">@item.Type · @item.PublishedAt.ToString("g")</div>
                                </div>
                                <span class="badge align-self-start @(item.IsPublished ? "text-bg-success" : "text-bg-secondary")">
                                    @(item.IsPublished ? "Published" : "Draft")
                                </span>
                            </div>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</div>
