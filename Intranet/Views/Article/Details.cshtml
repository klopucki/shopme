@model Core.Models.CMS.Article

@{
    ViewData["Title"] = "Article Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@Model.Title</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="card p-4 shadow-sm">
    <p class="text-secondary mb-2">@Model.ArticleCategory?.Name · @Model.PublishedAt.ToString("yyyy-MM-dd HH:mm")</p>
    <p><strong>Slug:</strong> @Model.Slug</p>
    <p><strong>Status:</strong> @(Model.IsPublished ? "Published" : "Draft")</p>
    <p>@Model.Summary</p>
    <hr />
    <div>@Html.Raw(Model.Content)</div>
</div>
