@model Core.Models.CMS.User

@{
    ViewData["Title"] = "Profile";
    var initials = Model.Username.Length >= 2
        ? Model.Username[..2].ToUpperInvariant()
        : Model.Username.ToUpperInvariant();
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Profile</h1>
        <p class="text-secondary mb-0">Your intranet account details.</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to dashboard
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center gap-4 mb-4">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-4 flex-shrink-0" style="width: 72px; height: 72px;">
                @initials
            </div>
            <div>
                <h2 class="h4 mb-1">@Model.Username</h2>
                <div class="text-secondary">@Model.Email</div>
            </div>
        </div>

        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">Username</dt>
            <dd class="col-sm-9 fw-semibold">@Model.Username</dd>

            <dt class="col-sm-3 text-secondary">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3 text-secondary">Created at</dt>
            <dd class="col-sm-9">@Model.CreatedAt</dd>

            <dt class="col-sm-3 text-secondary">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.IsActive ? "text-bg-success" : "text-bg-secondary")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </dd>
        </dl>
    </div>
</div>
