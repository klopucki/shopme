@model Intranet.Models.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Sign in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shop CRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">
<main class="min-vh-100 d-flex align-items-center justify-content-center p-3">
    <div class="card shadow-sm border-0" style="width: 100%; max-width: 420px;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
                    <i class="bi bi-cart4 fs-4"></i>
                </div>
                <h1 class="h4 mb-1">Shop CRM</h1>
                <p class="text-secondary mb-0">Sign in to the intranet.</p>
            </div>

            <form asp-action="Login" method="post" class="vstack gap-3">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="UsernameOrEmail" class="form-label"></label>
                    <input asp-for="UsernameOrEmail" class="form-control" autofocus />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
                </button>

                @if (ViewBag.CanCreateFirstUser == true)
                {
                    <a asp-action="Setup" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-person-plus me-1"></i>Create first user
                    </a>
                }
            </form>
        </div>
    </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
