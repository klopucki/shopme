@model Core.Models.Shop.Category

@{
    ViewData["Title"] = "Product Image Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Product image details</h1>
        <p class="text-secondary mb-0">@Model.Name</p>
    </div>
    <div class="btn-group">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Name)</dt>
            <dd class="col-sm-9 fw-semibold">@Html.DisplayFor(model => model.Name)</dd>
        </dl>
    </div>
</div>
