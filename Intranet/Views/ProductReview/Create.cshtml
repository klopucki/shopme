@model Core.Models.CMS.ProductReview

@{
    ViewData["Title"] = "Create Product Review";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Create product review</h1>
        <p class="text-secondary mb-0">Add feedback for a product.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" class="row g-3">
            <div asp-validation-summary="All" class="text-danger small col-12"></div>

            <div class="col-md-6">
                <label asp-for="ProductId" class="form-label"></label>
                <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId">
                    <option value="">Select product</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ReviewerName" class="form-label"></label>
                <input asp-for="ReviewerName" class="form-control" />
                <span asp-validation-for="ReviewerName" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Rating" class="form-label"></label>
                <input asp-for="Rating" class="form-control" />
                <span asp-validation-for="Rating" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Comment" class="form-label"></label>
                <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Comment" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
