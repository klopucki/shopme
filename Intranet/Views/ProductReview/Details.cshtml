@model Core.Models.CMS.ProductReview

@{
    ViewData["Title"] = "Product Review Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Product review details</h1>
        <p class="text-secondary mb-0">@Model.Product?.Name</p>
    </div>
    <div class="btn-group">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Product)</dt>
            <dd class="col-sm-9 fw-semibold">@Model.Product?.Name</dd>
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.ReviewerName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ReviewerName)</dd>
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Rating)</dt>
            <dd class="col-sm-9">
                <span class="badge text-bg-warning">@Html.DisplayFor(model => model.Rating) / 5</span>
            </dd>
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Comment)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Comment)</dd>
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>
        </dl>
    </div>
</div>
