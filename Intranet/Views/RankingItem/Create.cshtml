@model Core.Models.CMS.RankingItem

@{
    ViewData["Title"] = "Create Ranking Item";
}

<h1 class="h3 mb-4">Create Ranking Item</h1>

<div class="card p-4 shadow-sm">
    <form asp-action="Create">
        @await Html.PartialAsync("_RankingItemForm", Model)
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-controller="Ranking" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
