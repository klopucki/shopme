@model Core.Models.Shop.RankingItem

@{
    ViewData["Title"] = "Edit Ranking Item";
}

<h1 class="h3 mb-4">Edit Ranking Item</h1>

<div class="card p-4 shadow-sm">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        @await Html.PartialAsync("_RankingItemForm", Model)
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Ranking" asp-action="Details" asp-route-id="@Model.RankingId" class="btn btn-secondary">Back</a>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
