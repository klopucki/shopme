@model Core.Models.Shop.RankingItem

@{
    ViewData["Title"] = "Delete Ranking Item";
}

<h1 class="h3 mb-4">Delete Ranking Item</h1>

<div class="card p-4 shadow-sm">
    <p>Are you sure you want to delete <strong>@Model.Title</strong> from <strong>@Model.Ranking?.Title</strong>?</p>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="Ranking" asp-action="Details" asp-route-id="@Model.RankingId" class="btn btn-secondary">Back</a>
    </form>
</div>
