<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Shop CRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

<div class="container-fluid p-0">
    <div class="row g-0 min-vh-100">
        <!-- Sidebar -->
        <nav class="col-12 col-lg-2 bg-dark text-white sticky-lg-top shadow-sm d-flex flex-column">
            <div class="p-4 bg-black bg-opacity-25 text-center">
                <h5 class="mb-0 fw-bold text-truncate">
                    <i class="bi bi-cart4 me-2 text-primary"></i>SHOP CRM
                </h5>
            </div>
            
            <div class="py-3 flex-grow-1">
                <ul class="nav nav-pills flex-column px-2">
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "opacity-75")" 
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2 me-2"></i> Dashboard
                        </a>
                    </li>
                    
                    <li class="mt-4 px-3 mb-1 text-uppercase text-muted fw-bold small">
                        Catalog
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "opacity-75")" 
                           asp-controller="Product" asp-action="Index">
                            <i class="bi bi-box-seam me-2"></i> Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "opacity-75")" 
                           asp-controller="Category" asp-action="Index">
                            <i class="bi bi-tags me-2"></i> Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tag" ? "active" : "opacity-75")" 
                           asp-controller="Tag" asp-action="Index">
                            <i class="bi bi-hash me-2"></i> Tags
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductReview" ? "active" : "opacity-75")" 
                           asp-controller="ProductReview" asp-action="Index">
                            <i class="bi bi-chat-left-text me-2"></i> Product Reviews
                        </a>
                    </li>

                    <li class="mt-4 px-3 mb-1 text-uppercase text-muted fw-bold small">
                        Portal
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Article" ? "active" : "opacity-75")"
                           asp-controller="Article" asp-action="Index">
                            <i class="bi bi-newspaper me-2"></i> Articles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Page" || ViewContext.RouteData.Values["controller"]?.ToString() == "PageSection" ? "active" : "opacity-75")"
                           asp-controller="Page" asp-action="Index">
                            <i class="bi bi-file-earmark-richtext me-2"></i> Pages
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "ArticleCategory" ? "active" : "opacity-75")"
                           asp-controller="ArticleCategory" asp-action="Index">
                            <i class="bi bi-folder2-open me-2"></i> Article Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "ArticleTag" ? "active" : "opacity-75")"
                           asp-controller="ArticleTag" asp-action="Index">
                            <i class="bi bi-hash me-2"></i> Article Tags
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ranking" || ViewContext.RouteData.Values["controller"]?.ToString() == "RankingItem" ? "active" : "opacity-75")"
                           asp-controller="Ranking" asp-action="Index">
                            <i class="bi bi-trophy me-2"></i> Rankings
                        </a>
                    </li>

                    <li class="mt-4 px-3 mb-1 text-uppercase text-muted fw-bold small">
                        Admin
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "opacity-75")" 
                           asp-controller="User" asp-action="Index">
                            <i class="bi bi-people me-2"></i> Users
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "opacity-75")" 
                           asp-controller="Audit" asp-action="Index">
                            <i class="bi bi-journal-text me-2"></i> Audit Logs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white opacity-75" href="#">
                            <i class="bi bi-gear me-2"></i> Settings
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div class="col-12 col-lg-10 d-flex flex-column">
            <header class="navbar navbar-light bg-white border-bottom sticky-top px-4 py-2 shadow-sm justify-content-between">
                <div class="d-flex align-items-center">
                    <button class="btn btn-link d-lg-none text-dark me-2">
                        <i class="bi bi-list fs-3"></i>
                    </button>
                    <h6 class="mb-0 fw-semibold text-secondary">@ViewData["Title"]</h6>
                </div>

                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" id="userMenu" data-bs-toggle="dropdown">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold p-2 small">
                            AD
                        </div>
                        <span class="d-none d-sm-inline fw-medium">Administrator</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i> Profile</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i> Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i> Sign out</a></li>
                    </ul>
                </div>
            </header>

            <main class="p-4 flex-grow-1">
                @RenderBody()
            </main>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
