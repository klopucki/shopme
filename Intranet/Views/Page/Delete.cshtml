@model Core.Models.CMS.Page

@{
    ViewData["Title"] = "Delete Page";
}

<h1 class="h3 mb-4">Delete Page</h1>

<div class="alert alert-warning">Are you sure you want to delete this page and its sections?</div>

<div class="card p-4 shadow-sm">
    <h2 class="h5">@Model.Title</h2>
    <p class="text-secondary mb-4">/@Model.Slug</p>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>
