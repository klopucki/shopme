@model Core.Models.CMS.Page

@{
    ViewData["Title"] = Model.Title;
    var sections = Model.PageSections?.OrderBy(item => item.SortOrder).ToList() ?? [];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Title</h1>
        <p class="text-secondary mb-0">/@Model.Slug</p>
    </div>
    <div>
        <a asp-controller="PageSection" asp-action="Create" asp-route-pageId="@Model.Id" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add section</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit page</a>
    </div>
</div>

<div class="card p-4 shadow-sm mb-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">Summary</dt>
        <dd class="col-sm-9">@Model.Summary</dd>
        <dt class="col-sm-3">Published</dt>
        <dd class="col-sm-9">@(Model.IsPublished ? "Yes" : "No")</dd>
        <dt class="col-sm-3">Navigation</dt>
        <dd class="col-sm-9">@(Model.ShowInNavigation ? $"Visible, order {Model.NavigationOrder}" : "Hidden")</dd>
    </dl>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th>Order</th>
                <th>Type</th>
                <th>Title</th>
                <th>Active</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var pageSection in sections)
            {
                <tr>
                    <td>@pageSection.SortOrder</td>
                    <td><span class="badge text-bg-light">@pageSection.Type</span></td>
                    <td class="fw-semibold">@pageSection.Title</td>
                    <td>@(pageSection.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a asp-controller="PageSection" asp-action="Edit" asp-route-id="@pageSection.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                        <a asp-controller="PageSection" asp-action="Delete" asp-route-id="@pageSection.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
