@model Core.Models.CMS.Category

@{
    ViewData["Title"] = "Delete Product Tag";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Delete product tag</h1>
        <p class="text-secondary mb-0">Confirm removal of this product tag record.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <div>Are you sure you want to delete this product tag?</div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3 text-secondary">@Html.DisplayNameFor(model => model.Name)</dt>
            <dd class="col-sm-9 fw-semibold">@Html.DisplayFor(model => model.Name)</dd>
        </dl>
        <form asp-action="Delete" class="d-flex gap-2 mb-0">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
