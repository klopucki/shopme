@model Core.Models.CMS.PageSection

<section class="container py-5">
    <div class="mx-auto article-detail">
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <h2 class="fw-bold mb-3">@Model.Title</h2>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Content))
        {
            <div class="article-content">@Html.Raw(Model.Content)</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ButtonText) && !string.IsNullOrWhiteSpace(Model.ButtonUrl))
        {
            <a class="btn btn-dark rounded-pill px-4 mt-3" href="@Model.ButtonUrl">@Model.ButtonText</a>
        }
    </div>
</section>
