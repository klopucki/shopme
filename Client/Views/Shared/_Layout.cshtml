<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SHOP.ME</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="bg-white" style="font-family: 'Inter', sans-serif;">

<div class="bg-light py-2 border-bottom d-none d-md-block">
    <div class="container d-flex justify-content-between text-secondary small">
        <div><i class="bi bi-truck me-2"></i> Free delivery on orders over $50!</div>
        <div>
            <a href="#" class="text-decoration-none text-secondary me-3">Help</a>
            <a href="#" class="text-decoration-none text-secondary">Contact</a>
        </div>
    </div>
</div>

<header class="sticky-top shadow-sm bg-white">
    <nav class="navbar navbar-expand-lg navbar-light py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" asp-controller="Home" asp-action="Index" style="letter-spacing: -1px;">
                <i class="bi bi-bag-heart-fill text-danger me-1"></i>SHOP.ME
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link px-3 fw-medium" href="#">New Arrivals</a></li>
                    <li class="nav-item"><a class="nav-link px-3 fw-medium" href="#">Collections</a></li>
                    <li class="nav-item"><a class="nav-link px-3 fw-medium" href="#">Sale</a></li>
                    <li class="nav-item"><a class="nav-link px-3 fw-medium" href="#">About Us</a></li>
                </ul>
                
                <div class="d-flex align-items-center">
                    <a href="#" class="nav-link px-2 fs-5 text-dark"><i class="bi bi-search"></i></a>
                    <a href="#" class="nav-link px-2 fs-5 text-dark"><i class="bi bi-person"></i></a>
                    <a href="#" class="nav-link px-2 fs-5 text-dark position-relative">
                        <i class="bi bi-cart3"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark" style="font-size: 0.6rem;">0</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>
</header>

<main role="main" class="min-vh-100">
    @RenderBody()
</main>

<footer class="bg-dark text-white pt-5 pb-4 mt-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-5 mb-lg-0">
                <h6 class="text-uppercase fw-bold mb-4" style="letter-spacing: 1px;">About SHOP.ME</h6>
                <p class="text-white-50 pe-lg-5">Your favorite online boutique with curated clothing and accessories. Quality you can trust.</p>
                <div class="mt-4">
                    <a href="#" class="text-white-50 me-3 fs-5 text-decoration-none"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-white-50 me-3 fs-5 text-decoration-none"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-white-50 me-3 fs-5 text-decoration-none"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="col-6 col-lg-2 mb-5 mb-lg-0">
                <h6 class="text-uppercase fw-bold mb-4" style="letter-spacing: 1px;">Shop</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">All Products</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Categories</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">New Arrivals</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Bestsellers</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2 mb-5 mb-lg-0">
                <h6 class="text-uppercase fw-bold mb-4" style="letter-spacing: 1px;">Support</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Shipping</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Returns</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Terms of Service</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="text-uppercase fw-bold mb-4" style="letter-spacing: 1px;">Newsletter</h6>
                <p class="text-white-50">Subscribe to receive updates, access to exclusive deals, and more.</p>
                <form class="mt-3">
                    <div class="input-group">
                        <input type="email" class="form-control bg-transparent border-secondary text-white" placeholder="Your e-mail">
                        <button class="btn btn-outline-light" type="button">Join</button>
                    </div>
                </form>
            </div>
        </div>
        <hr class="mt-5 mb-4 border-secondary">
        <div class="row align-items-center">
            <div class="col-md-6 text-center text-md-start small text-white-50">
                &copy; @DateTime.Now.Year SHOP.ME. All rights reserved.
            </div>
            <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                <i class="bi bi-credit-card fs-4 me-2"></i>
                <i class="bi bi-paypal fs-4"></i>
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>