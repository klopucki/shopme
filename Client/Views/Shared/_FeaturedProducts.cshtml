@model IReadOnlyList<Core.Models.CMS.Product>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
        <div>
            <h2 class="fw-bold mb-0">Featured Products</h2>
            <p class="text-muted mb-0">Most recent items in the catalog</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-bold">View All</a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden">
                        <div class="bg-light">
                            <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/product-placeholder.svg") : product.ImageUrl)" class="card-img-top product-card-image" alt="@product.Name">
                        </div>
                        <div class="card-body px-0 pt-3">
                            <p class="text-muted small mb-1 text-center text-md-start">@product.Category?.Name</p>
                            <h6 class="fw-bold text-truncate mb-2 text-center text-md-start">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-dark text-decoration-none">@product.Name</a>
                            </h6>
                            <div class="mb-3 text-center text-md-start">
                                <span class="text-primary fw-bold fs-5">@product.Price.ToString("C")</span>
                            </div>
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button class="btn btn-dark w-100 rounded-pill py-2" type="submit">Add to Cart</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="border rounded-3 p-4 text-center text-muted">Featured products will appear here after they are marked as featured in the intranet.</div>
            </div>
        }
    </div>
</section>
