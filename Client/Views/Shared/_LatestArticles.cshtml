@model IReadOnlyList<Core.Models.CMS.Article>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
        <div>
            <h2 class="fw-bold mb-0">Latest Articles</h2>
            <p class="text-muted mb-0">Guides, news and shopping inspiration</p>
        </div>
        <a asp-controller="Article" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-bold">View Blog</a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            foreach (var article in Model)
            {
                <div class="col-md-4">
                    <article class="card h-100 border-0 shadow-sm overflow-hidden">
                        <img src="@(string.IsNullOrWhiteSpace(article.ImageUrl) ? $"https://picsum.photos/seed/article-{article.Id}/600/360" : article.ImageUrl)" class="card-img-top article-card-image" alt="@article.Title">
                        <div class="card-body">
                            <p class="text-muted small mb-2">@article.ArticleCategory?.Name · @article.PublishedAt.ToString("MMM d, yyyy")</p>
                            <h3 class="h5 fw-bold">@article.Title</h3>
                            <p class="text-muted">@article.Summary</p>
                            <a asp-controller="Article" asp-action="Details" asp-route-slug="@article.Slug" class="stretched-link text-decoration-none fw-semibold">Read article</a>
                        </div>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="border rounded-3 p-4 text-center text-muted">Articles will appear here after they are published in the intranet.</div>
            </div>
        }
    </div>
</section>
