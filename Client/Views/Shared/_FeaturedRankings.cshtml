@model IReadOnlyList<Core.Models.Shop.Ranking>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
        <div>
            <h2 class="fw-bold mb-0">Featured Rankings</h2>
            <p class="text-muted mb-0">Curated lists for faster decisions</p>
        </div>
        <a asp-controller="Ranking" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-bold">View Rankings</a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            foreach (var ranking in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <p class="text-muted small mb-2">@ranking.PublishedAt.ToString("MMM d, yyyy")</p>
                            <h3 class="h5 fw-bold">@ranking.Title</h3>
                            <p class="text-muted">@ranking.Summary</p>
                            <ol class="list-group list-group-numbered list-group-flush mb-3">
                                @foreach (var item in (ranking.RankingItems ?? []).OrderBy(item => item.Position).Take(3))
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-start">
                                        <span>@item.Title</span>
                                        <span class="badge text-bg-dark rounded-pill">@item.Score</span>
                                    </li>
                                }
                            </ol>
                            <a asp-controller="Ranking" asp-action="Details" asp-route-slug="@ranking.Slug" class="btn btn-dark rounded-pill px-4">Open Ranking</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="border rounded-3 p-4 text-center text-muted">Rankings will appear here after they are published in the intranet.</div>
            </div>
        }
    </div>
</section>
