@model IEnumerable<Core.Models.CMS.Ranking>

@{
    ViewData["Title"] = "Rankings";
}

<div class="container py-5">
    <div class="mb-5">
        <h1 class="fw-bold">Rankings</h1>
        <p class="text-muted mb-0">Curated recommendations and comparison lists.</p>
    </div>

    <div class="row g-4">
        @foreach (var ranking in Model)
        {
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="text-muted small mb-2">@ranking.PublishedAt.ToString("MMM d, yyyy")</p>
                        <h2 class="h5 fw-bold">@ranking.Title</h2>
                        <p class="text-muted">@ranking.Summary</p>
                        <a asp-action="Details" asp-route-slug="@ranking.Slug" class="btn btn-dark rounded-pill px-4">Open Ranking</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
