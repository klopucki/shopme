@model Core.Models.Shop.Ranking

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="mb-5">
        <p class="text-muted small mb-2">@Model.PublishedAt.ToString("MMM d, yyyy")</p>
        <h1 class="fw-bold">@Model.Title</h1>
        <p class="lead text-muted">@Model.Summary</p>
    </div>

    <div class="list-group shadow-sm">
        @foreach (var item in Model.RankingItems ?? [])
        {
            <a href="@(string.IsNullOrWhiteSpace(item.Url) ? "#" : item.Url)" class="list-group-item list-group-item-action p-4">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <p class="text-muted small mb-1">#@item.Position</p>
                        <h2 class="h5 fw-bold mb-2">@item.Title</h2>
                        <p class="text-muted mb-0">@item.Summary</p>
                    </div>
                    <span class="badge text-bg-dark rounded-pill align-self-start">@item.Score</span>
                </div>
            </a>
        }
    </div>
</div>
