@{
    ViewData["Title"] = "About Us";
}

<section class="about-hero bg-light border-bottom">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <p class="text-uppercase text-danger fw-bold small mb-2">SHOP.ME</p>
                <h1 class="display-5 fw-bold mb-3">Curated shopping, practical advice and honest recommendations.</h1>
                <p class="lead text-muted mb-4">
                    SHOP.ME is a small editorial commerce team focused on products that are useful, well-made and easy to compare.
                    We combine catalog browsing with buying guides, rankings and clear product details.
                </p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-dark btn-lg rounded-pill px-5">Browse Products</a>
            </div>
            <div class="col-lg-5">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=900&q=80"
                     class="img-fluid rounded-3 shadow-sm about-hero-image"
                     alt="Retail workspace with packages and laptop">
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="h-100 border rounded-3 p-4">
                <i class="bi bi-search-heart fs-2 text-danger"></i>
                <h2 class="h5 fw-bold mt-3">Curated Catalog</h2>
                <p class="text-muted mb-0">Products are organized by category, tag and editorial context so visitors can compare faster.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="h-100 border rounded-3 p-4">
                <i class="bi bi-journal-richtext fs-2 text-danger"></i>
                <h2 class="h5 fw-bold mt-3">Useful Content</h2>
                <p class="text-muted mb-0">Articles and guides help explain what matters before buying, without turning the site into a wall of ads.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="h-100 border rounded-3 p-4">
                <i class="bi bi-trophy fs-2 text-danger"></i>
                <h2 class="h5 fw-bold mt-3">Rankings</h2>
                <p class="text-muted mb-0">Shortlists highlight strong options for different needs, budgets and use cases.</p>
            </div>
        </div>
    </div>

    <div class="row g-5 align-items-start">
        <div class="col-lg-5">
            <h2 class="fw-bold mb-3">Visit Our Office</h2>
            <p class="text-muted">
                Our sample storefront and editorial office are based in San Francisco, close to Market Street and the downtown retail district.
            </p>
            <div class="vstack gap-3 mt-4">
                <div>
                    <div class="fw-bold">Address</div>
                    <div class="text-muted">1355 Market Street, Suite 900<br>San Francisco, CA 94103, USA</div>
                </div>
                <div>
                    <div class="fw-bold">Email</div>
                    <a href="mailto:hello@shopme.example" class="text-dark">hello@shopme.example</a>
                </div>
                <div>
                    <div class="fw-bold">Hours</div>
                    <div class="text-muted">Monday - Friday, 9:00 AM - 5:00 PM</div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow-sm border">
                <iframe
                    title="SHOP.ME office map"
                    src="https://www.openstreetmap.org/export/embed.html?bbox=-122.4219%2C37.7756%2C-122.4142%2C37.7799&amp;layer=mapnik&amp;marker=37.7766%2C-122.4172"
                    loading="lazy"></iframe>
            </div>
            <a class="d-inline-block mt-3 text-dark" href="https://www.openstreetmap.org/?mlat=37.7766&amp;mlon=-122.4172#map=17/37.7766/-122.4172" target="_blank" rel="noopener">
                Open larger map
            </a>
        </div>
    </div>
</section>
