@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="mb-5">
    <div class="container-fluid p-0">
        <div class="position-relative overflow-hidden p-5 bg-dark text-white text-center d-flex align-items-center justify-content-center min-vh-50" 
             style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://picsum.photos/id/20/1920/600') center/cover no-repeat; min-height: 500px;">
            <div class="col-md-8 py-5 mx-auto">
                <h1 class="display-3 fw-bold mb-3">New Collection 2024</h1>
                <p class="lead mb-4 px-lg-5">Discover the latest trends and find your unique style. Quality that speaks for itself.</p>
                <a class="btn btn-light btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm" href="#">Shop New Arrivals</a>
            </div>
        </div>
    </div>
</section>

<div class="container">
    <!-- Featured Categories -->
    <section class="mb-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-3">Popular Categories</h2>
            <hr class="mx-auto border-primary border-3 opacity-100" style="width: 50px;">
        </div>
        <div class="row g-4 text-center justify-content-center">
            <div class="col-6 col-md-2">
                <div class="p-4 rounded-circle bg-light mb-3 mx-auto shadow-sm d-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                    <i class="bi bi-laptop fs-1"></i>
                </div>
                <h6 class="fw-bold">Electronics</h6>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-4 rounded-circle bg-light mb-3 mx-auto shadow-sm d-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                    <i class="bi bi-watch fs-1"></i>
                </div>
                <h6 class="fw-bold">Accessories</h6>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-4 rounded-circle bg-light mb-3 mx-auto shadow-sm d-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                    <i class="bi bi-house fs-1"></i>
                </div>
                <h6 class="fw-bold">Home</h6>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-4 rounded-circle bg-light mb-3 mx-auto shadow-sm d-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                    <i class="bi bi-controller fs-1"></i>
                </div>
                <h6 class="fw-bold">Gaming</h6>
            </div>
        </div>
    </section>

    <!-- Products Grid -->
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
            <div>
                <h2 class="fw-bold mb-0">Featured Products</h2>
                <p class="text-muted mb-0">Most loved by our customers</p>
            </div>
            <a href="#" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-bold">View All</a>
        </div>

        <div class="row g-4">
            <!-- Product Card 1 -->
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm overflow-hidden">
                    <div class="position-relative bg-light">
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 rounded-pill">-20%</span>
                        <img src="https://picsum.photos/id/1/400/500" class="card-img-top" alt="Product">
                    </div>
                    <div class="card-body px-0 pt-3">
                        <p class="text-muted small mb-1 text-center text-md-start">Laptop</p>
                        <h6 class="fw-bold text-truncate mb-2 text-center text-md-start">Modern Laptop 2024</h6>
                        <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-3">
                            <span class="text-primary fw-bold fs-5">$1,199.00</span>
                            <span class="text-muted text-decoration-line-through ms-2 small">$1,499.00</span>
                        </div>
                        <button class="btn btn-dark w-100 rounded-pill py-2">Add to Cart</button>
                    </div>
                </div>
            </div>

            <!-- Product Card 2 -->
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm overflow-hidden">
                    <div class="bg-light">
                        <img src="https://picsum.photos/id/2/400/500" class="card-img-top" alt="Product">
                    </div>
                    <div class="card-body px-0 pt-3">
                        <p class="text-muted small mb-1 text-center text-md-start">Accessories</p>
                        <h6 class="fw-bold text-truncate mb-2 text-center text-md-start">Wireless Mouse Pro</h6>
                        <div class="mb-3 text-center text-md-start">
                            <span class="text-primary fw-bold fs-5">$49.00</span>
                        </div>
                        <button class="btn btn-dark w-100 rounded-pill py-2">Add to Cart</button>
                    </div>
                </div>
            </div>

            <!-- Product Card 3 -->
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm overflow-hidden">
                    <div class="bg-light">
                        <img src="https://picsum.photos/id/3/400/500" class="card-img-top" alt="Product">
                    </div>
                    <div class="card-body px-0 pt-3">
                        <p class="text-muted small mb-1 text-center text-md-start">Gaming</p>
                        <h6 class="fw-bold text-truncate mb-2 text-center text-md-start">Console Pro 5</h6>
                        <div class="mb-3 text-center text-md-start">
                            <span class="text-primary fw-bold fs-5">$499.00</span>
                        </div>
                        <button class="btn btn-dark w-100 rounded-pill py-2">Add to Cart</button>
                    </div>
                </div>
            </div>

            <!-- Product Card 4 -->
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm overflow-hidden">
                    <div class="bg-light">
                        <img src="https://picsum.photos/id/4/400/500" class="card-img-top" alt="Product">
                    </div>
                    <div class="card-body px-0 pt-3">
                        <p class="text-muted small mb-1 text-center text-md-start">Smartwatch</p>
                        <h6 class="fw-bold text-truncate mb-2 text-center text-md-start">Watch Ultra Plus</h6>
                        <div class="mb-3 text-center text-md-start">
                            <span class="text-primary fw-bold fs-5">$299.00</span>
                        </div>
                        <button class="btn btn-dark w-100 rounded-pill py-2">Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>