@model Client.Models.HomePageViewModel

@{
    ViewData["Title"] = "Home";
}

<section class="mb-5">
    <div class="container-fluid p-0">
        <div class="position-relative overflow-hidden p-5 bg-dark text-white text-center d-flex align-items-center justify-content-center min-vh-50"
             style="background: linear-gradient(rgba(0,0,0,0.42), rgba(0,0,0,0.42)), url('https://picsum.photos/id/20/1920/600') center/cover no-repeat; min-height: 500px;">
            <div class="col-md-8 py-5 mx-auto">
                <h1 class="display-3 fw-bold mb-3">New Collection 2026</h1>
                <p class="lead mb-4 px-lg-5">Discover curated products, expert articles and rankings made for smarter shopping.</p>
                <a class="btn btn-light btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm" asp-controller="Article" asp-action="Index">Read the Blog</a>
            </div>
        </div>
    </div>
</section>

<div class="container">
    @await Html.PartialAsync("_Categories", Model.Categories)
    @await Html.PartialAsync("_FeaturedProducts", Model.FeaturedProducts)
    @await Html.PartialAsync("_LatestArticles", Model.LatestArticles)
    @await Html.PartialAsync("_FeaturedRankings", Model.FeaturedRankings)
</div>
